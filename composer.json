{
    "name": "lattice/transport-rabbitmq",
    "description": "RabbitMQ transport adapter for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../contracts"
        }
    ],
    "require": {
        "php": "^8.4",
        "lattice/contracts": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Transport\\RabbitMq\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Transport\\RabbitMq\\Tests\\": "tests/"
        }
    }
}
